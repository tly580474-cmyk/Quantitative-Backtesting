# Phase 4.5: Data persistence mode
# 'indexeddb' — browser-only IndexedDB storage (default, no backend needed)
# 'api' — MySQL persistence via backend server
VITE_DATA_SOURCE=indexeddb
VITE_API_URL=http://localhost:3001

