# MySQL/API is the only authoritative writable data source.
VITE_DATA_SOURCE=api
VITE_API_URL=http://localhost:3001

# Legacy migration only: set both values below to read/export old browser data.
# IndexedDB migration mode is read-only and must be disabled after export.
VITE_ALLOW_INDEXEDDB_MIGRATION=false

