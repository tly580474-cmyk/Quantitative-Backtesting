{
  "name": "quant-backtest-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "tsx src/app.ts",
    "build": "tsc",
    "db:migrate": "tsx src/db/migrateCli.ts",
    "typecheck": "tsc --noEmit",
    "import:history": "tsx src/historyImport/cli.ts",
    "import:factors": "tsx src/historyImport/factorCli.ts",
    "benchmark:history": "tsx src/historyImport/benchmark.ts",
    "snapshot:build": "tsx src/research/snapshotCli.ts",
    "snapshot:publish": "tsx src/research/publishCli.ts",
    "snapshot:verify": "tsx src/research/verifyCli.ts",
    "snapshot:freshness": "tsx src/research/freshnessCli.ts",
    "snapshot:schedule:register": "powershell -NoProfile -ExecutionPolicy Bypass -File src/research/register-research-task.ps1",
    "index:update": "python src/referenceData/index_update.py",
    "index:backfill": "python src/referenceData/index_update.py --full",
    "index:test": "python -m unittest discover -s src/referenceData -p *_test.py",
    "index:constituents:update": "python src/referenceData/index_constituents_update.py",
    "index:constituents:dry-run": "python src/referenceData/index_constituents_update.py --dry-run",
    "dividend:update": "python src/referenceData/dividend_update.py --batch-size 200 --workers 8",
    "dividend:probe": "python src/referenceData/dividend_update.py --symbol 002155",
    "reference:status": "python src/referenceData/status.py",
    "snapshot:benchmark": "tsx src/research/benchmarkCli.ts",
    "duckdb": "tsx src/research/duckdbCli.ts",
    "minute:prepare": "python src/minuteData/prepare.py --start-year 2010 --end-year 2026",
    "minute:update": "python src/minuteData/update.py",
    "minute:update:dry-run": "python src/minuteData/update.py --dry-run",
    "minute:tdx:dry-run": "python src/minuteData/tdx_import.py --dry-run",
    "minute:tdx:probe": "python src/minuteData/tdx_import.py --probe-symbol 002155",
    "minute:tdx:import": "python src/minuteData/tdx_import.py",
    "minute:online:dry-run": "python src/minuteData/online_update.py --dry-run",
    "minute:online:probe": "python src/minuteData/online_update.py --probe-symbol 002155",
    "minute:online:health": "python src/minuteData/online_update.py --probe-count 100",
    "minute:online:update": "python src/minuteData/online_update.py",
    "minute:schedule:register": "powershell -NoProfile -ExecutionPolicy Bypass -File src/minuteData/register-task.ps1",
    "minute:test": "python -m unittest discover -s src/minuteData -p *_test.py",
    "backup:create": "tsx src/backup/backupCli.ts create",
    "backup:verify": "tsx src/backup/backupCli.ts verify",
    "backup:restore-check": "tsx src/backup/backupCli.ts restore-check",
    "factor:list": "tsx src/factorResearch/factorCli.ts list",
    "factor:run": "tsx src/factorResearch/factorCli.ts run",
    "factor:composite": "tsx src/factorResearch/factorCli.ts composite",
    "test": "vitest run src"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.4-r.1",
    "@fastify/cors": "^10.0.2",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "drizzle-zod": "^0.7.0",
    "fastify": "^5.2.0",
    "mysql2": "^3.13.0",
    "openai": "^5.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
