# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=quant_backtest

# Historical stock CSV root (contains 不复权/前复权/后复权)
STOCK_HISTORY_ROOT=D:\github_public_repo\所有股票的历史数据\每只股票一个文件

# AI Strategy Generation (Optional)
AI_STRATEGY_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=deepseek-v4-flash
OPENAI_TIMEOUT_MS=30000

# Market Data Sync (Phase 5, Optional)
MARKET_DATA_ENABLED=false
MARKET_DATA_PROVIDER=tencent
MARKET_DATA_API_KEY=
MARKET_DATA_BASE_URL=
MARKET_DATA_SYNC_TIME=15:10
# 交易时段内按分钟覆盖更新当天的未定稿日线；收盘任务再将其定稿。
MARKET_DATA_INTRADAY_INTERVAL_MINUTES=30

# Existing dataset-driven index updater
# Scans market_datasets and only updates existing index datasets.
MARKET_INDEX_AUTO_UPDATE_ENABLED=true
MARKET_CN_INDEX_UPDATE_TIME=15:10
MARKET_US_INDEX_UPDATE_TIME=15:10

# Phase 5.5 authoritative history path:
# legacy = old daily_candles only; prefer-v2 = v2 with legacy fallback; v2 = no fallback.
HISTORY_STORE_READ_MODE=prefer-v2
# Keep this true during the rollback window. Set false after v2 is formally accepted.
HISTORY_STORE_DUAL_WRITE=true

# Parquet + DuckDB research mirror
RESEARCH_SNAPSHOT_ROOT=./data/research-snapshots
BACKUP_ROOT=./data/backups
FACTOR_RESEARCH_ROOT=./data/factor-research
RESEARCH_QUERY_MAX_ROWS=10000

PORT=3001
