# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=quant_backtest

# Historical stock CSV root (contains 不复权/前复权/后复权)
STOCK_HISTORY_ROOT=D:\github_public_repo\所有股票的历史数据\每只股票一个文件

# AI Strategy Generation (Optional)
AI_STRATEGY_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=deepseek-v4-flash
OPENAI_TIMEOUT_MS=30000

# Market Data Sync (Phase 5, Optional)
MARKET_DATA_ENABLED=false
MARKET_DATA_PROVIDER=tencent
MARKET_DATA_API_KEY=
MARKET_DATA_BASE_URL=
MARKET_DATA_SYNC_TIME=15:30
# 个股日线仅在盘后定稿更新；盘中不会写入当天个股日线。
MARKET_DATA_INTRADAY_INTERVAL_MINUTES=30

# Full-market dragon-tiger list and market news collectors
DRAGON_TIGER_ENABLED=true
DRAGON_TIGER_SYNC_TIME=18:00
DRAGON_TIGER_RECHECK_TIME=18:30
MARKET_NEWS_ENABLED=true
MARKET_NEWS_REFRESH_INTERVAL_MINUTES=3
MARKET_NEWS_RETENTION_DAYS=3

# Market opinion agent scheduled email reports (Asia/Shanghai)
MARKET_OPINION_PUSH_ENABLED=false
MARKET_OPINION_MORNING_TIME=09:00
MARKET_OPINION_MIDDAY_TIME=12:00
MARKET_OPINION_CLOSE_TIME=16:00
MARKET_OPINION_PUSH_GRACE_MINUTES=20
MARKET_OPINION_PUSH_WEEKDAYS_ONLY=true
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
# Comma-separated recipients
MAIL_TO=

# Existing dataset-driven index updater
# Scans market_datasets and only updates existing index datasets.
MARKET_INDEX_AUTO_UPDATE_ENABLED=true
MARKET_CN_INDEX_UPDATE_TIME=20:00
MARKET_US_INDEX_UPDATE_TIME=05:00
RESEARCH_SNAPSHOT_MORNING_RETRY_TIME=08:30
RESEARCH_SNAPSHOT_UPDATE_TIME=18:00
RESEARCH_SNAPSHOT_RETRY_TIME=18:30
MINUTE_DATA_UPDATE_TIME=16:30
MINUTE_DATA_RETRY_TIME=17:30

# Phase 5.5 authoritative history path:
# legacy = old daily_candles only; prefer-v2 = v2 with legacy fallback; v2 = no fallback.
HISTORY_STORE_READ_MODE=prefer-v2
# Keep this true during the rollback window. Set false after v2 is formally accepted.
HISTORY_STORE_DUAL_WRITE=true

# Parquet + DuckDB research mirror
RESEARCH_SNAPSHOT_ROOT=./data/research-snapshots
# 自动清理只处理 manifest 合法的旧快照；当前版本和带 .retain 标记的目录永不删除。
RESEARCH_SNAPSHOT_RETENTION_ENABLED=true
RESEARCH_SNAPSHOT_RETAIN_LATEST=7
RESEARCH_SNAPSHOT_RETAIN_DAILY_DAYS=30
BACKUP_ROOT=./data/backups
FACTOR_RESEARCH_ROOT=./data/factor-research
FACTOR_MINER_PYTHON=python
FACTOR_MINER_ROOT=../tools/factor-miner
FACTOR_MINER_TIMEOUT_MS=21600000
FACTOR_MINER_MAX_MEMORY_MB=4096
RESEARCH_QUERY_MAX_ROWS=10000
# Historical 1-minute Parquet lake. Relative paths are resolved from server/.
# 当前按 2010-2026 接入；ZIP 根目录仅供 minute:prepare 使用。
MINUTE_DATA_ZIP_ROOT=../../所有股票的历史数据/1m_price_zip
MINUTE_DATA_ROOT=../../所有股票的历史数据/1m_price_parquet
MINUTE_QUERY_MAX_ROWS=100000
# Tushare 历史分钟接口需单独开通权限；minute:update 会自动读取 server/.env。
TUSHARE_TOKEN=
MINUTE_UPDATE_WORKERS=4
MINUTE_UPDATE_REQUESTS_PER_MINUTE=180
# 通达信客户端根目录，需先在客户端完成 1 分钟盘后数据下载。
TDX_DATA_ROOT=D:/tdx
MINUTE_ONLINE_WORKERS=8
MINUTE_ONLINE_RETRIES=3
MINUTE_ONLINE_DATALEN=1023
MINUTE_ONLINE_MIN_COVERAGE=0.995
DUCKDB_TEMP_ROOT=
DUCKDB_MAX_CONCURRENT=2
DUCKDB_MAX_QUEUED=8
DUCKDB_MAX_TEMP_SIZE=50GB

# Independent operations admin console.
# Generate a long random token. Leaving this empty disables /api/admin/*.
ADMIN_API_TOKEN=

PORT=3001
